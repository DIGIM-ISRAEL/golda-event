generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  admin
  sales
}

enum ClientType {
  institutional
  private
}

enum EventType {
  dairy
  parve
}

enum LeadStatus {
  lead
  quote_sent
  closed
  done
  canceled
}

enum FlavorCategory {
  dairy
  parve
}

enum DiscountType {
  percent
  fixed
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         Role     @default(sales)
  phoneNumber  String?  @map("phone_number")
  createdAt    DateTime @default(now()) @map("created_at")
  leads        Lead[]

  @@map("users")
}

model Settings {
  key   String @id
  value String

  @@map("settings")
}

model Location {
  id            String   @id @default(cuid())
  cityName      String   @map("city_name")
  travelCostNis Int      @map("travel_cost_nis")
  createdAt     DateTime @default(now()) @map("created_at")
  leads         Lead[]

  @@map("locations")
}

model Flavor {
  id             String         @id @default(cuid())
  name           String
  category       FlavorCategory
  isInStock      Boolean        @default(true) @map("is_in_stock")
  sortOrder      Int            @default(0) @map("sort_order")
  costPerBasketa Float?         @map("cost_per_basketa")
  createdAt      DateTime       @default(now()) @map("created_at")
  leadFlavors    LeadFlavor[]

  @@map("flavors")
}

model Lead {
  id                     String     @id @default(cuid())
  clientName             String     @map("client_name")
  clientPhone            String     @map("client_phone")
  clientType             ClientType @map("client_type")
  eventType              EventType  @map("event_type")
  eventDate              String     @map("event_date")
  startTime              String     @map("start_time")
  endTime                String     @map("end_time")
  locationId             String?    @map("location_id")
  participants           Int
  status                 LeadStatus @default(lead)
  salesRepId             String?    @map("sales_rep_id")
  notes                  String?
  managerIncluded        Boolean    @default(true) @map("manager_included")
  assistantsCount        Int        @default(0) @map("assistants_count")
  priceOverride          Float?     @map("price_override")
  pricePerPersonOverride Float?     @map("price_per_person_override")
  signatureToken         String     @unique @default(cuid()) @map("signature_token")
  checklistToken         String     @unique @default(cuid()) @map("checklist_token")
  clientApprovedAt       DateTime?  @map("client_approved_at")
  clientApprovedName     String?    @map("client_approved_name")
  clientApprovedIp       String?    @map("client_approved_ip")
  clientSignature        String?    @map("client_signature")
  quoteSentAt            DateTime?  @map("quote_sent_at")
  quoteViewedAt          DateTime?  @map("quote_viewed_at")
  followupStage          Int        @default(0) @map("followup_stage")
  googleEventId          String?    @map("google_event_id")
  airtableRecordId       String?    @unique @map("airtable_record_id")
  checkedItems           String[]   @default([]) @map("checked_items")
  includedItems          String[]   @default([]) @map("included_items")
  customChecklistItems   String[]   @default([]) @map("custom_checklist_items")
  eventLog               Json?      @map("event_log")
  costReportSentAt       DateTime?  @map("cost_report_sent_at")
  reminderSentAt         DateTime?  @map("reminder_sent_at")
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")

  location Location?    @relation(fields: [locationId], references: [id])
  salesRep User?        @relation(fields: [salesRepId], references: [id])
  flavors  LeadFlavor[]
  quote    Quote?

  @@map("leads")
}

model LeadFlavor {
  leadId   String @map("lead_id")
  flavorId String @map("flavor_id")

  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  flavor Flavor @relation(fields: [flavorId], references: [id])

  @@id([leadId, flavorId])
  @@map("lead_flavors")
}

model Quote {
  id            String        @id @default(cuid())
  leadId        String        @unique @map("lead_id")
  basePrice     Float         @map("base_price")
  vatAmount     Float?        @map("vat_amount")
  logisticsCost Float         @map("logistics_cost")
  extras        Json          @default("[]")
  discountType  DiscountType? @map("discount_type")
  discountValue Float         @default(0) @map("discount_value")
  advancePaid   Float         @default(0) @map("advance_paid")
  balanceDue    Float         @map("balance_due")
  totalPrice    Float         @map("total_price")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("quotes")
}
